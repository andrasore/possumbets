{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "init": {
      "inputs": ["package.json", "pyproject.toml"],
      "outputs": ["node_modules/**", ".venv/**"]
    },
    "build": {
      "dependsOn": ["init"],
      "inputs": ["src/**"],
      "outputs": ["dist/**", ".next/**"]
    },
    "proto:gen": {
      "inputs": ["../../proto/**/*.proto"],
      "outputs": ["src/generated/**"]
    },
    "typecheck": {
      "dependsOn": ["build"],
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.py",
        "tsconfig.json",
        "pyproject.toml"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": [
        "src/**",
        "test/**",
        "jest.config.js",
        "tsconfig.json"
      ],
      "outputs": []
    },
    "e2e": {
      "cache": false,
      "persistent": false
    }
  }
}
