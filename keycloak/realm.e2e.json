{
  "realm": "betting",
  "enabled": true,
  "registrationAllowed": true,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "sslRequired": "none",
  "accessTokenLifespan": 1800,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Administrator \u2014 access to admin pages"
      },
      {
        "name": "user",
        "description": "Regular user"
      }
    ]
  },
  "defaultRole": {
    "name": "default-roles-betting",
    "composite": true,
    "composites": {
      "realm": [
        "user"
      ],
      "client": {
        "account": [
          "view-profile",
          "manage-account"
        ]
      }
    }
  },
  "clients": [
    {
      "clientId": "betting-frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:13000/*"
      ],
      "webOrigins": [
        "http://localhost:13000",
        "http://localhost:18080"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:13000/*"
      }
    },
    {
      "clientId": "betting-core",
      "enabled": true,
      "publicClient": false,
      "secret": "betting-core-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "redirectUris": []
    }
  ],
  "users": [
    {
      "username": "service-account-betting-core",
      "enabled": true,
      "serviceAccountClientId": "betting-core",
      "clientRoles": {
        "realm-management": [
          "view-users",
          "query-users"
        ]
      }
    },
    {
      "username": "alice",
      "email": "alice@example.com",
      "firstName": "Alice",
      "lastName": "Example",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    },
    {
      "username": "bob",
      "email": "admin@example.com",
      "firstName": "Bob",
      "lastName": "Example",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin",
        "user"
      ]
    }
  ]
}
